---
import Noir from '../../layouts/Noir.astro';
import ConnectCTA from '../../components/ConnectCTA.astro';

// Faithful to the live /wedding-musicians-and-band/ — each instrument is its own
// section with an alternating video + heading + verbatim description.
// Videos mapped to instruments by their real YouTube titles (via oEmbed).
// Trombone & Trumpet share the generic "Event DJ's, Live Bands & Productions" reel,
// exactly as on the live site. (Only the obvious typo "versatilily" was corrected.)
const sections = [
  { title: 'Ceremony string Trio', video: 'kur8aZh6TaE', body: "Elevate your wedding, gala, or corporate event with the refined sound of our string trio. Blending classical elegance with modern flair, our musicians deliver a live soundtrack that's both sophisticated and unforgettable." },
  { title: 'Ceremony string Quartet', video: '5E8n8fhcnjU', body: 'From live guitar, sax, percussion, to keyboards and violins – our ceremony quartet brings a rich, versatile sound to weddings, corporate events, and upscale gatherings. Elegant, energetic, unforgettable.' },
  { title: 'Guitar', video: '03jFGbBTNGU', body: 'From intimate acoustics to high energy sets, our professional guitarists enhance weddings, corporate events, and private celebrations with versatility and high-quality live music.' },
  { title: 'Percussion', video: 'KBa74FMdbhM', body: 'From djembes and congas to timbales and drum sets, our percussionists infuse weddings, corporate events, and celebrations with vibrant, global rhythms and high-energy flair.' },
  { title: 'Piano/Keyboard', video: '7HmSttPpWOM', body: 'Add elegance and emotion to your event with live piano or keyboard. From classical to contemporary, our talented musicians elevate weddings, corporate galas, and private gatherings with soulful, tailored performances.' },
  { title: 'Saxophone', video: '5qSrXW0ifeE', body: 'Add soul and sophistication to your event with live saxophone. From smooth jazz to pop & classical, the best saxophonists create unforgettable atmospheres for weddings, corporates, and upscale celebrations.' },
  { title: 'Trombone', video: 'm5lPf8I4Xys', body: 'Add bold, expressive sound to your event with live trombone. From jazz and orchestral to brass ensembles and solos, our trombonists bring depth, energy, and elegance to any occasion.' },
  { title: 'Trumpet', video: 'm5lPf8I4Xys', body: 'Add a regal, uplifting sound to your event with live trumpet. From wedding processionals to jazz nights and grand openings, our skilled trumpeters deliver bold, expressive performances that leave a lasting impression.' },
];
---

<Noir
  title="Wedding Musicians and Band"
  description="Live wedding and event musicians in South Florida — string trio & quartet, guitar, percussion, piano, saxophone, trombone, and trumpet by Avinu Music & Productions."
>
  <!-- COMPACT PAGE HEADER -->
  <section class="page-head">
    <div class="ph-inner">
      <p class="eyebrow" data-reveal>Live Music</p>
      <h1 data-reveal>Musicians</h1>
    </div>
  </section>

  <!-- INSTRUMENT / ENSEMBLE SECTIONS — alternating video + text (verbatim copy) -->
  {sections.map((s, i) => (
    <section class={`band feature-band ${i % 2 === 1 ? 'midnight' : ''}`}>
      <div class={`feature ${i % 2 === 0 ? 'reverse' : ''}`} data-reveal>
        <div class="f-text">
          <h2>{s.title}</h2>
          <p>{s.body}</p>
        </div>
        <div class="f-media">
          <iframe src={`https://www.youtube-nocookie.com/embed/${s.video}`} title={s.title} loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
        </div>
      </div>
    </section>
  ))}

  <ConnectCTA />

  <style>
    .page-head { padding: 5.5rem 1.5rem 1rem; }
    .ph-inner { max-width: 60rem; margin: 0 auto; text-align: center; }
    .page-head h1 { font-size: clamp(2.6rem, 6vw, 4.6rem); margin: 1rem 0 0; }

    .band { padding: 3.75rem 1.5rem; }
    .band.midnight { background: var(--midnight); }
    .feature { max-width: var(--maxw); margin: 0 auto; display: grid; grid-template-columns: 1fr 1.1fr; gap: 3rem; align-items: center; }
    .feature.reverse { grid-template-columns: 1.1fr 1fr; }
    .feature.reverse .f-text { order: 2; }
    .f-text h2 { font-size: clamp(1.6rem, 3.2vw, 2.3rem); margin-bottom: 1rem; }
    .f-text p { color: var(--muted-text); margin: 0; font-size: 1.04rem; line-height: 1.75; }
    .f-media { aspect-ratio: 16 / 9; border-radius: 16px; overflow: hidden; border: 1px solid var(--line); background: #000; }
    .f-media iframe { width: 100%; height: 100%; border: 0; display: block; }

    @media (max-width: 820px) {
      .feature, .feature.reverse { grid-template-columns: 1fr; gap: 1.75rem; }
      .feature.reverse .f-text { order: 0; }
    }

    @media (prefers-reduced-motion: no-preference) {
      :global(html.js) [data-reveal] { opacity: 0; }
    }
  </style>

  <script>
    import { animate, inView } from 'motion';
    if (matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      inView('[data-reveal]', (el) => {
        animate(el, { opacity: [0, 1], y: [28, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
      }, { margin: '0px 0px -10% 0px' });
    }
  </script>
</Noir>
