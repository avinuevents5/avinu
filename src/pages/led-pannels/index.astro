---
import Noir from '../../layouts/Noir.astro';
import ConnectCTA from '../../components/ConnectCTA.astro';
import VideoGallery from '../../components/VideoGallery.astro';

const U = '/wp-content/uploads';
const hero = `${U}/2025/05/photography-with-natural.jpg`;

// Copy + gallery from led-pannels.md. Real URL keeps the live's "led-pannels" spelling
// for SEO continuity; the visible heading fixes the obvious typo to "LED Panels".
const gallery = [
  { src: `${U}/2023/08/LED-Walls-scaled.jpg`, alt: 'LED screens behind a live band' },
  { src: `${U}/2023/08/dcffa581-bea0-42d1-ae4f-0f7e5f8f927d.jpg`, alt: 'DJ setup and stage' },
  { src: `${U}/2023/08/ed692027-7b42-4d54-a5fe-c8c24bca4627.jpg`, alt: 'DJ setup and stage' },
  { src: `${U}/2023/08/IMG_0270.jpg`, alt: 'DJ setup and stage' },
  { src: `${U}/2023/08/6a6581ad-ad94-4ffb-a6ff-38b77fdd9550.jpg`, alt: 'Bar mitzvah setup with LED screens' },
  { src: `${U}/2023/08/7b0628ea-c8f4-44a8-91de-6160500c803b.jpg`, alt: 'DJ setup' },
  { src: `${U}/2023/08/a38dac23-92e3-4d6d-8fc7-6148ec01b115.jpg`, alt: 'Bar mitzvah setup' },
  { src: `${U}/2023/08/c13fb55b-0923-419e-9c88-0bf2e2d6e9d0.jpg`, alt: 'DJ setup' },
];
---

<Noir
  title="LED Panels"
  description="Cutting-edge LED wall technology for events in South Florida. Immersive screens and stunning visuals for corporate gatherings, live performances and conferences by Avinu Music & Productions."
>
  <!-- ░░ HERO IMAGE HEADER ░░ -->
  <section class="detail-hero" style={`background-image:url('${hero}')`}>
    <div class="dh-scrim"></div>
    <div class="dh-content">
      <p class="eyebrow">Full Production · Screens</p>
      <h1>LED Panels</h1>
    </div>
  </section>

  <!-- ░░ INTRO COPY ░░ -->
  <section class="band">
    <p class="intro-lead" data-reveal>
      Elevate your events to new heights with our cutting-edge LED wall technology. Our LED walls
      aren't just displays — they're immersive experiences that captivate your audience.
    </p>
    <p class="intro-body" data-reveal>
      Imagine vibrant visuals and stunning graphics that come to life in breathtaking detail,
      creating an atmosphere that's nothing short of magical. Whether it's a corporate gathering, a
      live performance or a conference, our LED walls add that "wow" factor that leaves a lasting
      impression on everyone in attendance. Get ready to transform your events into unforgettable
      moments with our state-of-the-art LED wall solutions.
    </p>
  </section>

  <!-- ░░ GALLERY ░░ -->
  <section class="band midnight">
    <header class="band-head" data-reveal><p class="eyebrow">In the room</p><h2>Recent installs</h2></header>
    <div class="gallery" data-reveal-group>
      {gallery.map((g) => (
        <div class="g-cell"><img src={g.src} alt={g.alt} loading="lazy" /></div>
      ))}
    </div>
  </section>

  <VideoGallery videos={['hrpzEtYvuzw']} />

  <ConnectCTA />

  <style>
    .detail-hero { position: relative; min-height: 56vh; display: flex; align-items: flex-end; background-size: cover; background-position: center; }
    .dh-scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(8,9,12,0.95) 0%, rgba(8,9,12,0.45) 55%, rgba(8,9,12,0.55) 100%); }
    .dh-content { position: relative; z-index: 2; max-width: var(--maxw); margin: 0 auto; width: 100%; padding: 3rem 1.5rem 3.5rem; }
    .dh-content h1 { font-size: clamp(2.8rem, 8vw, 5.5rem); margin: 0.8rem 0 0; }
    .dh-sub { color: #d8d1c4; font-size: clamp(1rem, 2vw, 1.25rem); max-width: 40rem; margin: 1.2rem 0 0; }

    .band { padding: 5rem 1.5rem; }
    .band > * { max-width: var(--maxw); margin-left: auto; margin-right: auto; }
    .band.midnight { background: var(--midnight); }
    .band-head { text-align: center; margin-bottom: 3rem; }
    .band-head h2 { font-size: clamp(2rem, 4.5vw, 3.2rem); margin-top: 0.5rem; }
    .intro-lead { font-family: var(--font-display); font-size: clamp(1.35rem, 2.8vw, 2rem); line-height: 1.4; text-align: center; max-width: 48rem; }
    .intro-body { color: var(--muted-text); max-width: 48rem; text-align: center; margin-top: 1.5rem; font-size: 1.05rem; }

    .gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    .g-cell { border-radius: 14px; overflow: hidden; aspect-ratio: 4 / 3; }
    .g-cell img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.16,1,0.3,1); }
    .g-cell:hover img { transform: scale(1.06); }

    @media (max-width: 820px) { .gallery { grid-template-columns: repeat(2, 1fr); } }

    @media (prefers-reduced-motion: no-preference) {
      :global(html.js) [data-reveal],
      :global(html.js) [data-reveal-group] > * { opacity: 0; }
    }
  </style>

  <script>
    import { animate, inView, stagger } from 'motion';
    inView('[data-reveal]', (el) => {
      animate(el, { opacity: [0, 1], y: [30, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
    }, { margin: '0px 0px -12% 0px' });
    document.querySelectorAll('[data-reveal-group]').forEach((group) => {
      inView(group, () => {
        animate(Array.from(group.children), { opacity: [0, 1], y: [30, 0] },
          { delay: stagger(0.07), duration: 0.7, ease: [0.16, 1, 0.3, 1] });
      }, { margin: '0px 0px -10% 0px' });
    });
  </script>
</Noir>
