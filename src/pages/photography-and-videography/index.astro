---
import Noir from '../../layouts/Noir.astro';
import ConnectCTA from '../../components/ConnectCTA.astro';
import VideoGallery from '../../components/VideoGallery.astro';

const U = '/wp-content/uploads';
const hero = `${U}/2025/05/videogr.jpg`;

// Copy verbatim from photography-and-videography.md
const weddingsBody = "Our in-house video team has over a decade with hundreds of events under their belt. We tailor our solutions to your needs and we'll schedule you on a meeting with the exact team you will be working with, so you can feel confident knowing every detail is being documented to perfection.";
const corporateBody = 'From Product Photography to a full scale Video commercials, we help your brand stand out by delivering a bold message. It brings your products and services in front of your targeted audience. To better showcase our solutions, we invite you to meet our team in person, discuss our solutions and make smart decisions.';

const weddingVideo = 'X3xPz-d98Os'; // "Wedding Show Reel"
// Recent Events — only the videos that actually play (2 LatinAutor-blocked ones removed).
const recentEvents = ['oBL_H8XKbig', 'S0fqtXoaJjE', 'cJQImsRtJ3Y', 'JIt6VlFl5qc', 'VaB64VImqyU'];
const capabilities = ['Drone photo & video', 'Live broadcast & streaming', 'Digital albums'];
---

<Noir
  title="Photography and Videography"
  description="Best wedding videography and photography in Miami. An in-house team with a decade of weddings, events and commercial work — drone, live streaming and digital albums by Avinu Music & Productions."
>
  <!-- HERO -->
  <section class="detail-hero" style={`background-image:url('${hero}')`}>
    <div class="dh-scrim"></div>
    <div class="dh-content">
      <p class="eyebrow">Full Production · Photo &amp; Video</p>
      <h1>Best Wedding Videography in Miami</h1>
    </div>
  </section>

  <!-- WEDDINGS AND EVENTS — text + featured video -->
  <section class="band">
    <div class="feature" data-reveal>
      <div class="feature-text">
        <h2>Weddings and Events</h2>
        <p>{weddingsBody}</p>
      </div>
      <div class="feature-video">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${weddingVideo}`}
          title="Avinu Music & Productions — Wedding Show Reel"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CORPORATE & COMMERCIAL -->
  <section class="band midnight">
    <div class="corporate" data-reveal>
      <h2>Corporate &amp; Commercial</h2>
      <p>{corporateBody}</p>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="band">
    <header class="band-head" data-reveal><p class="eyebrow">Capabilities</p><h2>How we capture it</h2></header>
    <div class="cap-row" data-reveal-group>
      {capabilities.map((c) => (
        <div class="cap"><span class="dot"></span>{c}</div>
      ))}
    </div>
  </section>

  <!-- RECENT EVENTS -->
  <VideoGallery heading="Recent Events" videos={recentEvents} />

  <ConnectCTA />

  <style>
    .detail-hero { position: relative; min-height: 56vh; display: flex; align-items: flex-end; background-size: cover; background-position: center; }
    .dh-scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(8,9,12,0.95) 0%, rgba(8,9,12,0.45) 55%, rgba(8,9,12,0.55) 100%); }
    .dh-content { position: relative; z-index: 2; max-width: var(--maxw); margin: 0 auto; width: 100%; padding: 3rem 1.5rem 3.5rem; }
    .dh-content h1 { font-size: clamp(2.8rem, 8vw, 5.5rem); margin: 0.8rem 0 0; }

    .band { padding: 5rem 1.5rem; }
    .band > * { max-width: var(--maxw); margin-left: auto; margin-right: auto; }
    .band.midnight { background: var(--midnight); }
    .band-head { text-align: center; margin-bottom: 3rem; }
    .band-head h2 { font-size: clamp(2rem, 4.5vw, 3.2rem); margin-top: 0.5rem; }

    /* WEDDINGS feature row */
    .feature { display: grid; grid-template-columns: 1fr 1.1fr; gap: 3rem; align-items: center; }
    .feature-text h2 { font-size: clamp(1.7rem, 3.4vw, 2.4rem); margin-bottom: 1rem; }
    .feature-text p { color: var(--muted-text); margin: 0; font-size: 1.05rem; line-height: 1.75; }
    .feature-video { aspect-ratio: 16 / 9; border-radius: 16px; overflow: hidden; border: 1px solid var(--line); background: #000; }
    .feature-video iframe { width: 100%; height: 100%; border: 0; display: block; }

    /* CORPORATE */
    .corporate { max-width: 60rem; text-align: center; }
    .corporate h2 { font-size: clamp(1.7rem, 3.4vw, 2.4rem); margin-bottom: 1rem; }
    .corporate p { color: var(--muted-text); margin: 0; font-size: 1.05rem; line-height: 1.75; }

    .cap-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .cap { display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.85rem 1.8rem; border: 1px solid var(--line); border-radius: 999px; font-family: var(--font-display); font-size: 1.2rem; }
    .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); }

    @media (max-width: 820px) { .feature { grid-template-columns: 1fr; gap: 2rem; } }

    @media (prefers-reduced-motion: no-preference) {
      :global(html.js) [data-reveal],
      :global(html.js) [data-reveal-group] > * { opacity: 0; }
    }
  </style>

  <script>
    import { animate, inView, stagger } from 'motion';
    inView('[data-reveal]', (el) => {
      animate(el, { opacity: [0, 1], y: [30, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
    }, { margin: '0px 0px -12% 0px' });
    document.querySelectorAll('[data-reveal-group]').forEach((group) => {
      inView(group, () => {
        animate(Array.from(group.children), { opacity: [0, 1], y: [30, 0] },
          { delay: stagger(0.1), duration: 0.7, ease: [0.16, 1, 0.3, 1] });
      }, { margin: '0px 0px -10% 0px' });
    });
  </script>
</Noir>
