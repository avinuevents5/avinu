---
import Noir from '../layouts/Noir.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const singers = await getCollection('singers');
  return singers.map((e) => ({ params: { singer: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, role, photo, languages = [], specialties = [], gallery = [], videos = [], audio = [], summary, connectNote } = entry.data;
const firstName = title.split(' ')[0];

const others = (await getCollection('singers'))
  .filter((e) => e.id !== entry.id)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((e) => ({ name: e.data.title, photo: e.data.photo ?? '', href: `/${e.id}/` }));
---

<Noir title={title} description={summary ?? role}>
  <!-- COMPACT HEADER -->
  <section class="page-head">
    <div class="ph-inner">
      <p class="eyebrow" data-reveal>Vocalist</p>
      <h1 data-reveal>{title}</h1>
      {role && <p class="role" data-reveal>{role}</p>}
    </div>
  </section>

  <!-- BIO + PHOTO -->
  <section class="band">
    <div class="bio-grid">
      <div class="bio" data-reveal>
        <div class="prose"><Content /></div>
        <div class="facts-row">
          {languages.length > 0 && (
            <div class="fact"><h3>Fluent Languages</h3><p>{languages.join(', ')}</p></div>
          )}
          {specialties.length > 0 && (
            <div class="fact"><h3>Specializes In</h3><p>{specialties.join(', ')}</p></div>
          )}
        </div>
        <a class="btn-primary bio-cta" href="/get-a-quote/">Book {firstName}</a>
      </div>
      <div class="bio-photo" data-reveal>
        <div class="bp-img" style={`background-image:url('${photo}')`}></div>
      </div>
    </div>
  </section>

  <!-- VIDEOS -->
  {videos.length > 0 && (
    <section class="band midnight">
      <header class="band-head" data-reveal><p class="eyebrow">Watch</p><h2>Videos</h2></header>
      <div class="videos" data-reveal-group>
        {videos.map((v) => (
          <div class="video">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${v}`}
              title={`${title} — video`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- LISTEN / SONGS -->
  {audio.length > 0 && (
    <section class="band">
      <header class="band-head" data-reveal><p class="eyebrow">Listen</p><h2>Songs</h2></header>
      <div class="tracks" data-reveal>
        {audio.map((src) => (
          <iframe class="sc-player" width="100%" height="420" scrolling="no" frameborder="no" loading="lazy" src={src}></iframe>
        ))}
      </div>
    </section>
  )}

  <!-- GALLERY (only if present) -->
  {gallery.length > 0 && (
    <section class="band midnight">
      <header class="band-head" data-reveal><p class="eyebrow">Gallery</p><h2>On the stage</h2></header>
      <div class="gallery" data-reveal-group>
        {gallery.map((src) => (
          <div class="g-cell"><div class="g-img" style={`background-image:url('${src}')`}></div></div>
        ))}
      </div>
    </section>
  )}

  <!-- CONNECT WITH {NAME} -->
  <section class="band connect">
    <div class="connect-inner">
      <h2 data-reveal>Connect with {title}</h2>
      {connectNote && <p class="connect-note" data-reveal>{connectNote}</p>}
      <div class="connect-cols" data-reveal-group>
        <div class="ccol">
          <h3>Call Now</h3>
          <p>Instantly connect with {title} and discuss your requirements.</p>
          <a class="btn-primary" href="tel:+17545474415">Call Now</a>
        </div>
        <div class="ccol">
          <h3>Book Now</h3>
          <p>Save a date and let {firstName} mesmerize your audience.</p>
          <a class="btn-primary" href="/get-a-quote/">Book Now</a>
        </div>
        <div class="ccol">
          <h3>Contact Us</h3>
          <p>For general inquiries, collaborations, or feedback, reach out to us.</p>
          <a class="btn-primary" href="/get-a-quote/">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- OTHER SINGERS -->
  <section class="band midnight">
    <header class="band-head" data-reveal><p class="eyebrow">More voices</p><h2>Other Singers</h2></header>
    <div class="others" data-reveal-group>
      {others.map((o) => (
        <a class="person" href={o.href}>
          <div class="person-img" style={`background-image:url('${o.photo}')`}></div>
          <span class="person-name">{o.name}</span>
        </a>
      ))}
    </div>
  </section>

  <style>
    /* COMPACT HEADER */
    .page-head { padding: 5.5rem 1.5rem 0.5rem; text-align: center; }
    .ph-inner { max-width: 60rem; margin: 0 auto; }
    .page-head h1 { font-size: clamp(2.8rem, 7vw, 5rem); margin: 0.8rem 0 0; }
    .role { color: var(--accent-soft); font-family: var(--font-display); font-style: italic; font-size: clamp(1.05rem, 2.4vw, 1.5rem); margin: 0.7rem 0 0; }

    /* SHELL */
    .band { padding: 4.5rem 1.5rem; }
    .band > * { max-width: var(--maxw); margin-left: auto; margin-right: auto; }
    .band.midnight { background: var(--midnight); }
    .band-head { text-align: center; margin-bottom: 3rem; }
    .band-head h2 { font-size: clamp(2rem, 4.5vw, 3rem); margin-top: 0.5rem; }

    /* BIO + PHOTO */
    .bio-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 3.5rem; align-items: start; }
    .prose :global(p) { color: #d8d1c4; font-size: 1.05rem; line-height: 1.78; margin: 0 0 1.25rem; }
    .prose :global(p:first-child) { font-family: var(--font-display); font-size: 1.3rem; line-height: 1.5; color: var(--fg); }
    .facts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin: 2rem 0; }
    .fact h3 { font-family: var(--font-body); font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.7rem; color: var(--accent); margin-bottom: 0.5rem; }
    .fact p { color: var(--fg); font-size: 0.95rem; margin: 0; }
    .bio-photo { position: sticky; top: 6rem; }
    .bp-img { aspect-ratio: 4 / 5; border-radius: 18px; background-size: cover; background-position: center; border: 1px solid var(--line); }

    /* VIDEOS */
    .videos { display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 1.5rem; max-width: 920px; margin: 0 auto; }
    .video { aspect-ratio: 16 / 9; border-radius: 14px; overflow: hidden; border: 1px solid var(--line); background: #000; }
    .video iframe { width: 100%; height: 100%; border: 0; display: block; }

    /* SONGS */
    .tracks { max-width: 820px; margin: 0 auto; display: grid; gap: 1.25rem; }
    .sc-player { border: 1px solid var(--line); border-radius: 14px; display: block; }

    /* GALLERY */
    .gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    .g-cell { border-radius: 14px; overflow: hidden; }
    .g-img { aspect-ratio: 3 / 4; background-size: cover; background-position: center; transition: transform 0.6s cubic-bezier(0.16,1,0.3,1); }
    .g-cell:hover .g-img { transform: scale(1.06); }

    /* CONNECT */
    .connect-inner { max-width: var(--maxw); }
    .connect h2 { font-family: var(--font-display); font-style: italic; font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 2.5rem; }
    .connect-cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .ccol h3 { font-family: var(--font-body); font-weight: 700; font-size: 1.05rem; margin-bottom: 0.6rem; }
    .ccol p { color: var(--muted-text); font-size: 0.95rem; line-height: 1.6; margin: 0 0 1.2rem; min-height: 3.2em; }
    .connect-note { color: var(--muted-text); font-size: 1.05rem; line-height: 1.7; max-width: 52rem; margin: 0 0 2.8rem; }

    /* OTHER SINGERS */
    .others { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    .person { position: relative; display: block; border-radius: 16px; overflow: hidden; }
    .person-img { aspect-ratio: 3 / 4; background-size: cover; background-position: center top; transition: transform 0.6s cubic-bezier(0.16,1,0.3,1); }
    .person:hover .person-img { transform: scale(1.06); }
    .person::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent 55%); }
    .person-name { position: absolute; left: 1rem; bottom: 0.9rem; z-index: 2; font-family: var(--font-display); font-size: 1.2rem; }

    @media (max-width: 900px) {
      .bio-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .bio-photo { position: static; order: -1; }
      .bp-img { aspect-ratio: 16 / 10; }
      .gallery { grid-template-columns: repeat(2, 1fr); }
      .connect-cols { grid-template-columns: 1fr; gap: 1.5rem; }
      .ccol p { min-height: 0; }
      .others { grid-template-columns: 1fr; }
    }
    @media (max-width: 520px) { .videos { grid-template-columns: 1fr; } .facts-row { grid-template-columns: 1fr; } }

    @media (prefers-reduced-motion: no-preference) {
      :global(html.js) [data-reveal],
      :global(html.js) [data-reveal-group] > * { opacity: 0; }
    }
  </style>

  <script>
    import { animate, inView, stagger } from 'motion';
    if (matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      inView('[data-reveal]', (el) => {
        animate(el, { opacity: [0, 1], y: [28, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
      }, { margin: '0px 0px -10% 0px' });
      document.querySelectorAll('[data-reveal-group]').forEach((group) => {
        inView(group, () => {
          animate(Array.from(group.children), { opacity: [0, 1], y: [28, 0] },
            { delay: stagger(0.08), duration: 0.7, ease: [0.16, 1, 0.3, 1] });
        }, { margin: '0px 0px -10% 0px' });
      });
    }
  </script>
</Noir>
