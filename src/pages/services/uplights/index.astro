---
import Noir from '../../../layouts/Noir.astro';
import ConnectCTA from '../../../components/ConnectCTA.astro';

const U = '/wp-content/uploads';
const hero = `${U}/2018/12/weddings1.jpg`;

// Copy from uplights.md.
const sections = [
  {
    title: 'Lighting',
    body: "We know that the importance of your wedding day surpasses that of any other celebration. That's why it is our priority to ensure your special day comes to life in exactly the way you imagined.",
  },
  {
    title: 'Intelligent dance floor Lighting',
    body: "Revitalize the dance floor with a novel energy that's impossible to resist. Intelligent dance lights move and shift to the beat of the music, reinventing the light-and-sound relationship on the dance floor.",
  },
  {
    title: 'Bistro Lighting',
    body: 'This ultra-festive yet undeniably romantic detail can revamp any space, indoors or out. Bistro lighting is just the thing to compliment a night under the stars, or to expand upon the warmth that fills an indoor venue.',
  },
  {
    title: 'Show Mapping',
    body: 'Show mapping projection technology turns any object into a display surface for video projection. Fill the room with colours and designs to add a modern wow-factor to your event.',
  },
  {
    title: 'Gobo Monogram',
    body: "Let us create a customized logo of your event. Give us the name of your mitzvah-boy or mitzvah-girl, the initials of the newly-weds, or simply hand us your existing company logo, and we'll project it onto the dance floor and the walls of the venue. This special touch is the perfect way to put the guests of honor in the spotlight.",
  },
  {
    title: 'Pinspot lighting',
    body: "Pinspot lighting highlights the details that you've put so much thought into selecting. Enhance your flower displays, centerpieces, cake, or sweetheart table to up the elegance of your special day.",
  },
];
---

<Noir
  title="Uplights"
  description="Wireless uplighting and full lighting design in South Florida — intelligent dance lighting, bistro lighting, show mapping, gobo monograms and pinspot lighting by Avinu Music & Productions."
>
  <!-- ░░ HERO IMAGE HEADER ░░ -->
  <section class="detail-hero" style={`background-image:url('${hero}')`}>
    <div class="dh-scrim"></div>
    <div class="dh-content">
      <p class="eyebrow">Full Production · Uplights</p>
      <h1>Uplights</h1>
    </div>
  </section>

  <!-- ░░ CONTENT SECTIONS ░░ -->
  <section class="band">
    <div class="rows" data-reveal-group>
      {sections.map((s) => (
        <article class="row">
          <h2>{s.title}</h2>
          <p>{s.body}</p>
        </article>
      ))}
    </div>
  </section>

  <ConnectCTA />

  <style>
    .detail-hero { position: relative; min-height: 56vh; display: flex; align-items: flex-end; background-size: cover; background-position: center; }
    .dh-scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(8,9,12,0.95) 0%, rgba(8,9,12,0.45) 55%, rgba(8,9,12,0.55) 100%); }
    .dh-content { position: relative; z-index: 2; max-width: var(--maxw); margin: 0 auto; width: 100%; padding: 3rem 1.5rem 3.5rem; }
    .dh-content h1 { font-size: clamp(2.8rem, 8vw, 5.5rem); margin: 0.8rem 0 0; }
    .dh-sub { color: #d8d1c4; font-size: clamp(1rem, 2vw, 1.25rem); max-width: 40rem; margin: 1.2rem 0 0; }

    .band { padding: 5rem 1.5rem; }
    .band > * { max-width: var(--maxw); margin-left: auto; margin-right: auto; }

    .rows { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem 3rem; }
    .row h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); margin-bottom: 0.7rem; }
    .row p { color: var(--muted-text); margin: 0; font-size: 1.02rem; }

    @media (max-width: 820px) { .rows { grid-template-columns: 1fr; gap: 2.25rem; } }

    @media (prefers-reduced-motion: no-preference) {
      :global(html.js) [data-reveal],
      :global(html.js) [data-reveal-group] > * { opacity: 0; }
    }
  </style>

  <script>
    import { animate, inView, stagger } from 'motion';
    inView('[data-reveal]', (el) => {
      animate(el, { opacity: [0, 1], y: [30, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
    }, { margin: '0px 0px -12% 0px' });
    document.querySelectorAll('[data-reveal-group]').forEach((group) => {
      inView(group, () => {
        animate(Array.from(group.children), { opacity: [0, 1], y: [30, 0] },
          { delay: stagger(0.08), duration: 0.7, ease: [0.16, 1, 0.3, 1] });
      }, { margin: '0px 0px -10% 0px' });
    });
  </script>
</Noir>
