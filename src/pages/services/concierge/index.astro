---
import Noir from '../../../layouts/Noir.astro';
import ConnectCTA from '../../../components/ConnectCTA.astro';

const U = '/wp-content/uploads';
const hero = `${U}/2018/12/yachts1.jpg`;

// Copy from concierge.md (VIP Concierge).
const offerings = [
  {
    title: 'Yacht Rentals',
    img: `${U}/2018/12/yachts1.jpg`,
    body: "Dream vacations come to life. If you've ever fantasized about yourself at sea, we're here to make this a reality. Complemented with bartenders, masseuse, private chef, or a full stocked bar with snacks – let's create your vision together.",
  },
  {
    title: 'Jet Ski Rentals',
    img: `${U}/2018/12/jetski1.jpg`,
    body: 'Excitement and adrenaline. A great addition to your yacht rentals as a full day adventure, with a specialist available for tours around the islands and Intercoastal.',
  },
];
---

<Noir
  title="VIP Concierge"
  description="VIP concierge in Miami — luxury yacht and jet-ski rentals, private chefs, bartenders and bespoke on-the-water experiences by Avinu Music & Productions."
>
  <!-- ░░ HERO IMAGE HEADER ░░ -->
  <section class="detail-hero" style={`background-image:url('${hero}')`}>
    <div class="dh-scrim"></div>
    <div class="dh-content">
      <p class="eyebrow">Full Production · Concierge</p>
      <h1>VIP Concierge</h1>
    </div>
  </section>

  <!-- ░░ OFFERINGS ░░ -->
  <section class="band">
    <div class="offers" data-reveal-group>
      {offerings.map((o, i) => (
        <article class={`offer ${i % 2 ? 'reverse' : ''}`}>
          <div class="offer-media"><div class="offer-img" style={`background-image:url('${o.img}')`}></div></div>
          <div class="offer-text">
            <h2>{o.title}</h2>
            <p>{o.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <ConnectCTA />

  <style>
    .detail-hero { position: relative; min-height: 56vh; display: flex; align-items: flex-end; background-size: cover; background-position: center; }
    .dh-scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(8,9,12,0.95) 0%, rgba(8,9,12,0.45) 55%, rgba(8,9,12,0.55) 100%); }
    .dh-content { position: relative; z-index: 2; max-width: var(--maxw); margin: 0 auto; width: 100%; padding: 3rem 1.5rem 3.5rem; }
    .dh-content h1 { font-size: clamp(2.8rem, 8vw, 5.5rem); margin: 0.8rem 0 0; }
    .dh-sub { color: #d8d1c4; font-size: clamp(1rem, 2vw, 1.25rem); max-width: 40rem; margin: 1.2rem 0 0; }

    .band { padding: 5rem 1.5rem; }
    .band > * { max-width: var(--maxw); margin-left: auto; margin-right: auto; }

    .offers { display: grid; gap: 4rem; }
    .offer { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
    .offer.reverse .offer-media { order: 2; }
    .offer-img { aspect-ratio: 4 / 3; background-size: cover; background-position: center; border-radius: 18px; }
    .offer-text h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem; }
    .offer-text p { color: var(--muted-text); margin: 0; font-size: 1.05rem; }

    @media (max-width: 820px) {
      .offer, .offer.reverse { grid-template-columns: 1fr; gap: 1.75rem; }
      .offer.reverse .offer-media { order: 0; }
    }

    @media (prefers-reduced-motion: no-preference) {
      :global(html.js) [data-reveal],
      :global(html.js) [data-reveal-group] > * { opacity: 0; }
    }
  </style>

  <script>
    import { animate, inView, stagger } from 'motion';
    inView('[data-reveal]', (el) => {
      animate(el, { opacity: [0, 1], y: [30, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
    }, { margin: '0px 0px -12% 0px' });
    document.querySelectorAll('[data-reveal-group]').forEach((group) => {
      inView(group, () => {
        animate(Array.from(group.children), { opacity: [0, 1], y: [30, 0] },
          { delay: stagger(0.12), duration: 0.7, ease: [0.16, 1, 0.3, 1] });
      }, { margin: '0px 0px -10% 0px' });
    });
  </script>
</Noir>
