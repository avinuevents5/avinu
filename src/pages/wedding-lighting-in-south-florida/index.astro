---
import Noir from '../../layouts/Noir.astro';
import ConnectCTA from '../../components/ConnectCTA.astro';

const U = '/wp-content/uploads';
const hero = `${U}/2025/05/tyle-is-candid-image.jpg`;

// Faithful structure from the live /wedding-lighting-in-south-florida/ — 5 subsections,
// each with its mapped video (matched by YouTube title) or image. The LED Walls video
// (TcSr2pd1R3E "Mapping Projector") is LatinAutor-blocked on the live, so it's omitted.
const sections = [
  {
    title: 'Dancing in the clouds',
    body: ['Imagine your first dance over a sky of clouds, a sensation of flight, romantic and mesmerizing. This special effect brings a new element to your event, sometimes combined with our LED Pannels, or event fireworks.'],
    video: 'UwyP7aMuBjs',
  },
  {
    title: 'Uplighting and Dance Lighting',
    body: [
      'Wireless uplighting is the sure-fire way to transform any space by making a bold and radiant statement. Be it a deep violet or a modern pink, uplights set the vibe of your event from the moment your guests enter the room.',
      "Revitalize the dance floor with a novel energy that's impossible to resist. Intelligent dance lights move and shift to the beat of the music, reinventing the light-and-sound relationship on the dance floor.",
    ],
    video: '9arpVI8Rc0Y',
  },
  {
    title: 'Bistro Lighting',
    body: ['This magical detail can revamp any space, indoors or outdoors. Bistro lighting is the key to create a night under the stars, or to expand upon the warmth that fills the ambience of your event.'],
    video: 'XgxZH9Z0jHQ',
  },
  {
    title: 'LED Walls, LED Dance Floor, and Show mapping',
    body: ['Our seasoned day-of-coordinators make sure everything is executed as planned. They manage your event, so that you can focus on what matters: being fully present and celebrating your connection to one another, just as you pictured.'],
  },
  {
    title: 'Gobo Monogram',
    body: ['We create a customized logo (or your names) in pure lighting to enhance your event. With high lumen projectors, your branded logo can be displayed on the floor, on the walls, or in the draping (in many occasions). In addition, we offer the service of pinspot lighting, enhancing the floral designs in a dimmed room. These are the spotlights for your special displays, centerpieces, cake, and all the significant areas for that "wow" factor that we all envision.'],
    image: `${U}/2023/05/gobo.jpg`,
  },
];
---

<Noir
  title="Lighting"
  description="Wedding and event lighting in South Florida — uplighting, intelligent dance lighting, bistro lighting, LED walls, show mapping and custom gobo monograms by Avinu Music & Productions."
>
  <section class="detail-hero" style={`background-image:url('${hero}')`}>
    <div class="dh-scrim"></div>
    <div class="dh-content"><h1>Lighting for weddings &amp; special events</h1></div>
  </section>

  {sections.map((s, i) => (
    <section class={`band feature-band ${i % 2 === 1 ? 'midnight' : ''}`}>
      <div class={`feature ${i % 2 === 1 ? 'reverse' : ''} ${!s.video && !s.image ? 'solo' : ''}`} data-reveal>
        <div class="f-text">
          <h2>{s.title}</h2>
          {s.body.map((p) => <p>{p}</p>)}
        </div>
        {s.video && (
          <div class="f-media">
            <iframe src={`https://www.youtube-nocookie.com/embed/${s.video}`} title={s.title} loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
          </div>
        )}
        {s.image && <div class="f-img" style={`background-image:url('${s.image}')`}></div>}
      </div>
    </section>
  ))}

  <ConnectCTA />

  <style>
    .detail-hero { position: relative; min-height: 48vh; display: flex; align-items: center; justify-content: center; text-align: center; background-size: cover; background-position: center; }
    .dh-scrim { position: absolute; inset: 0; background: radial-gradient(120% 100% at 50% 50%, rgba(8,9,12,0.5), rgba(8,9,12,0.82)); }
    .dh-content { position: relative; z-index: 2; padding: 4rem 1.5rem; }
    .dh-content h1 { font-size: clamp(2.2rem, 6vw, 4rem); }

    .band { padding: 4.5rem 1.5rem; }
    .band.midnight { background: var(--midnight); }
    .feature { max-width: var(--maxw); margin: 0 auto; display: grid; grid-template-columns: 1fr 1.1fr; gap: 3rem; align-items: center; }
    .feature.reverse { grid-template-columns: 1.1fr 1fr; }
    .feature.reverse .f-text { order: 2; }
    .feature.solo { grid-template-columns: 1fr; max-width: 60rem; text-align: center; }
    .f-text h2 { font-size: clamp(1.6rem, 3.2vw, 2.3rem); margin-bottom: 1rem; }
    .f-text p { color: var(--muted-text); margin: 0 0 1rem; font-size: 1.04rem; line-height: 1.75; }
    .f-media { aspect-ratio: 16 / 9; border-radius: 16px; overflow: hidden; border: 1px solid var(--line); background: #000; }
    .f-media iframe { width: 100%; height: 100%; border: 0; display: block; }
    .f-img { aspect-ratio: 4 / 3; border-radius: 16px; background-size: cover; background-position: center; border: 1px solid var(--line); }

    @media (max-width: 820px) {
      .feature, .feature.reverse { grid-template-columns: 1fr; gap: 1.75rem; }
      .feature.reverse .f-text { order: 0; }
    }

    @media (prefers-reduced-motion: no-preference) {
      :global(html.js) [data-reveal] { opacity: 0; }
    }
  </style>

  <script>
    import { animate, inView } from 'motion';
    inView('[data-reveal]', (el) => {
      animate(el, { opacity: [0, 1], y: [28, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
    }, { margin: '0px 0px -10% 0px' });
  </script>
</Noir>
